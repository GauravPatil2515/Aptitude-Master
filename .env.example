# AptitudeMaster environment template
# Copy to `.env` and fill in real values. `.env` is git-ignored.
# Used ONLY by the Vercel Edge proxy (api/groq.js) in production mode.
# In local/dev mode the Groq key is supplied per-user via the Settings panel
# (stored in localStorage as `groq_api_key`) — never committed to the repo.

# Server-side Groq API key (Vercel dashboard / .env in production only)
GROQ_API_KEY=
